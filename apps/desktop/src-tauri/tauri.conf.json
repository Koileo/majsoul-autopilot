{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Majsoul Autopilot",
  "version": "0.1.0",
  "identifier": "com.happyshine.majsoul-autopilot",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Majsoul Autopilot",
        "width": 1440,
        "height": 900,
        "minWidth": 1180,
        "minHeight": 760
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.icns",
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "resources": {
      "../../../models/mortal": "models/mortal",
      "../../../settings.example.json": "settings.example.json"
    },
    "macOS": {
      "signingIdentity": "-",
      "hardenedRuntime": false
    }
  }
}
