{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "description": "Minimal settings for pure Liqi protocol autoplay.",
  "properties": {
    "model_path": {
      "type": "string",
      "description": "Path to the Mortal .pth model file."
    },
    "autoplay_account": {
      "type": "object",
      "properties": {
        "username": { "type": "string" },
        "password": { "type": "string" }
      },
      "required": ["username", "password"],
      "additionalProperties": false
    }
  },
  "required": [
    "model_path",
    "autoplay_account"
  ],
  "additionalProperties": false
}
